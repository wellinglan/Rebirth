REBIRTH_ENV=development
REBIRTH_DATABASE_URL=postgresql+psycopg://rebirth:change-me@postgres:5432/rebirth
REBIRTH_JWT_SECRET=replace-with-a-long-random-development-secret
REBIRTH_ACCESS_TOKEN_MINUTES=30
REBIRTH_REFRESH_TOKEN_DAYS=30
POSTGRES_DB=rebirth
POSTGRES_USER=rebirth
POSTGRES_PASSWORD=change-me
REBIRTH_AI_PROVIDER=disabled
OPENAI_API_KEY=replace-only-in-local-or-managed-secret-storage
REBIRTH_AI_MODEL=replace-with-a-supported-model
REBIRTH_AI_TIMEOUT_SECONDS=90
REBIRTH_AI_MAX_OUTPUT_TOKENS=1600
REBIRTH_AI_FAKE_SCENARIO=success
REBIRTH_AI_RESULT_RETENTION_HOURS=24
REBIRTH_AI_DEDUPE_RETENTION_DAYS=30
REBIRTH_AI_PROCESSING_LEASE_MINUTES=5
